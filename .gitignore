# Runtime knowledge store (regenerated at run time; may cache CC BY-SA text)
data/*.sqlite3
data/*.sqlite3-wal
data/*.sqlite3-shm

# Vendored OS packages -- install foma via the system package manager instead
data/vendor/*.deb

# Editor / OS cruft
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
