# Python
__pycache__/
*.py[cod]
*.egg
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Test / coverage caches
.pytest_cache/
pytest-cache-files-*/
.coverage
